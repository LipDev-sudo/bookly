# ============================================================
# Horavia — modelo de variáveis de ambiente
# Copy this file to `.env.local` and fill in your own values.
# ============================================================

# ---------- Supabase ----------
# Get these from: https://supabase.com/dashboard/project/_/settings/api-keys
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxx
SUPABASE_SECRET_KEY=sb_secret_xxxxx

# ---------- Stripe (test mode) ----------
# Get these from: https://dashboard.stripe.com/test/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_SECRET_KEY=sk_test_xxxxx

# Optional: webhook secret from `stripe listen --forward-to localhost:3000/api/stripe/webhook`
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# ---------- App ----------
NEXT_PUBLIC_APP_URL=http://localhost:3000
